{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@/tw": [
        "./src/tw/index"
      ],
      "@/tw/image": [
        "./src/tw/image"
      ],
      "@/tw/animated": [
        "./src/tw/animated"
      ],
      "@/theme": [
        "./src/theme/index"
      ],
      "@/lib/*": [
        "./src/lib/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}